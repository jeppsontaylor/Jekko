{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "jekko",
  "description": "AI-powered development tool",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run --cwd packages/jekko --conditions=browser src/index.ts",
    "lint": "oxlint",
    "build": "just build-fast",
    "fast": "just fast",
    "fast:build": "just build-fast",
    "fast:test": "just test-fast",
    "fast:typecheck": "just typecheck-fast",
    "workspace:fast": "just workspace-fast",
    "workspace:build": "just workspace-build-fast",
    "workspace:build-fast": "just workspace-build-fast",
    "workspace:test": "just workspace-test-fast",
    "workspace:test-fast": "just workspace-test-fast",
    "workspace:typecheck": "just workspace-typecheck-fast",
    "workspace:typecheck-fast": "just workspace-typecheck-fast",
    "test": "just test-fast",
    "typecheck": "just typecheck-fast",
    "postinstall": "bun run --cwd packages/jekko fix-node-pty",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.57",
      "@effect/platform-node": "4.0.0-beta.57",
      "@npmcli/arborist": "9.4.0",
      "@types/bun": "1.3.12",
      "@types/cross-spawn": "6.0.6",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "@opentui/core": "0.2.2",
      "@opentui/solid": "0.2.2",
      "ulid": "3.0.1",
      "@types/node": "24.12.2",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@pierre/diffs": "1.1.0-beta.18",
      "opentui-spinner": "0.0.6",
      "diff": "8.0.2",
      "drizzle-kit": "1.0.0-beta.19-d95b7a4",
      "drizzle-orm": "1.0.0-beta.19-d95b7a4",
      "effect": "4.0.0-beta.59",
      "ai": "6.0.168",
      "cross-spawn": "7.0.6",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "remeda": "2.26.0",
      "semver": "7.7.4",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "solid-js": "1.9.10",
      "@lydell/node-pty": "1.2.0-beta.10"
    }
  },
  "devDependencies": {
    "@actions/artifact": "5.0.1",
    "@tsconfig/bun": "catalog:",
    "@types/mime-types": "3.0.1",
    "@typescript/native-preview": "catalog:",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.6.2",
    "semver": "^7.6.0",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "@jekko-ai/plugin": "workspace:*",
    "@jekko-ai/script": "workspace:*",
    "@jekko-ai/sdk": "workspace:*",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/jekko"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "tree-sitter-powershell",
    "web-tree-sitter"
  ],
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "patchedDependencies": {
    "@npmcli/agent@4.0.0": "patches/@npmcli%2Fagent@4.0.0.patch",
    "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch"
  }
}
