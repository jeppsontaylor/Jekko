# Provenance: compact appendix excerpt from docs/ZYAL/examples/07-self-improving-skills.zyal.
<<<ZYAL v1:daemon id=self-improving-skills>>>
version: v1
intent: daemon
confirm: RUN_FOREVER
job:
  name: "Self-improving skills"
  objective: "Let agents propose skills, quarantine them, and require review before promotion."
stop:
  all:
    - shell: { command: "just fast", timeout: 10m, assert: { exit_code: 0 } }
skills:
  registry:
    reviewer:
      description: "Review candidate skill diffs."
      trust: builtin
      writes: none
    skill-author:
      description: "Draft skill improvements in quarantine."
      trust: unverified
      writes: isolated_worktree
  allow_creation: true
  max_skills: 5
memory:
  stores:
    skill_lessons:
      scope: repo
      retention: permanent
      write_policy: append_only
approvals:
  gates:
    skill_promotion:
      required_role: human_operator
      timeout: 48h
      decisions: [approve, reject]
quality:
  anti_vibe:
    enabled: true
    block_fake_data_fallback: true
    block_ts_ignore: true
observability:
  spans: { emit: all, include_tool_calls: true }
  metrics:
    - { name: quarantined_skills, type: counter, source: runtime }
    - { name: promoted_skills, type: counter, source: runtime }
done:
  require: [skill_diff_reviewed, tests_pass, promotion_approved]
<<<END_ZYAL id=self-improving-skills>>>
ZYAL_ARM RUN_FOREVER id=self-improving-skills
