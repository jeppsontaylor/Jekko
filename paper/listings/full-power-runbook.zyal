# Provenance: compact appendix excerpt from docs/ZYAL/examples/08-full-power-runbook.zyal.
<<<ZYAL v1:daemon id=full-power-runbook>>>
version: v1
intent: daemon
confirm: RUN_FOREVER
job:
  name: "Full-power guarded runbook"
  objective: "Run autonomous engineering with leases, budgets, rollback, and evidence gates."
loop:
  policy: forever
  circuit_breaker: { max_consecutive_errors: 3, on_trip: pause }
stop:
  all:
    - shell: { command: "just fast", timeout: 10m, assert: { exit_code: 0 } }
arming:
  preview_hash_required: true
  host_nonce_required: true
  accepted_origins: [trusted_user_message, signed_cli_input]
  arm_token_single_use: true
capabilities:
  default: deny
  rules:
    - { id: read-all, tool: read, paths: ["**"], decision: allow, expires: 2h }
    - { id: edit-owned, tool: edit, paths: ["packages/jekko/src/**"], decision: allow, expires: 1h }
    - { id: test-lane, tool: shell, command_regex: "^(just fast|bun test)", decision: allow }
  command_floor:
    always_block: ["git push --force", "rm -rf /", "sudo ", "DROP DATABASE"]
budgets:
  run: { wall_clock: 4h, cost_usd: 25, on_exhaust: renew_with_approval }
  iteration: { tokens: 200000, tool_calls: 120, on_exhaust: pause }
rollback:
  plan_required: true
  verify_command: "git apply --reverse --check patch.diff"
done:
  require: [tests_pass, proof_bundle_signed, rollback_verified]
  forbid: [deleted_tests, weakened_assertions, unchecked_ts_ignore]
observability:
  spans: { emit: all, include_tool_calls: true, include_model_calls: true }
  cost: { budget: 25, currency: USD, alert_at_percent: 80, on_budget_exceeded: pause }
fleet:
  max_workers: 8
  isolation: git_worktree
<<<END_ZYAL id=full-power-runbook>>>
ZYAL_ARM RUN_FOREVER id=full-power-runbook
