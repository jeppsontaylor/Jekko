# Provenance: compact appendix excerpt from docs/ZYAL/examples/05-secure-mcp-lockdown.zyal.yml.
<<<ZYAL v1:daemon id=secure-mcp-lockdown>>>
version: v1
intent: daemon
confirm: RUN_FOREVER
job:
  name: "Secure MCP lockdown"
  objective: "Use only explicit MCP profiles, brokered secrets, and sandboxed execution."
stop:
  all:
    - git_clean: { allow_untracked: false }
mcp:
  profiles:
    docs-readonly:
      servers: ["filesystem"]
      tools: ["read"]
      resources: ["docs/**", "packages/**/README.md"]
permissions:
  shell: ask
  edit: ask
  git_commit: ask
  git_push: deny
  mcp: ask
capabilities:
  default: deny
  rules:
    - { id: mcp-docs, tool: mcp, mcp_profile: docs-readonly, decision: allow, expires: 30m }
    - { id: repo-read, tool: read, paths: ["docs/**", "packages/**"], decision: allow }
  command_floor:
    always_block:
      - "curl .*\\|.*sh"
      - "git push --force"
      - "rm -rf /"
      - "printenv"
sandbox:
  paths:
    - { path: "docs/", access: read }
    - { path: "packages/", access: read }
    - { path: ".env", access: deny }
  network:
    outbound: deny
  env_deny: [AWS_SECRET_ACCESS_KEY, OPENAI_API_KEY, GITHUB_TOKEN]
security:
  secrets:
    allowed_env: []
    redact_from_logs: true
  injection:
    scan_inputs: true
    scan_outputs: true
    deny_patterns: ["ignore previous instructions", "exfiltrate", "printenv"]
    on_detect: pause
<<<END_ZYAL id=secure-mcp-lockdown>>>
ZYAL_ARM RUN_FOREVER id=secure-mcp-lockdown
