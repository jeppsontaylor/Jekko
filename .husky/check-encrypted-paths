#!/usr/bin/env bash
# ── Husky pre-commit: verify jnoccio-fusion encryption ──────────
# Advisory guard that catches plaintext commits locally before push.
# CI is the real enforcement gate; this is a developer convenience.
# ────────────────────────────────────────────────────────────────

# Only run if git-crypt is installed (non-keyholders may not have it)
if ! command -v git-crypt &>/dev/null; then
  exit 0
fi

# Check staged files in protected paths
STAGED=$(git diff --cached --name-only -- 'jnoccio-fusion/')

if [[ -z "$STAGED" ]]; then
  exit 0  # No protected files staged
fi

MAGIC_HEX="00474954435259505400"
EXCEPTIONS=(
  "jnoccio-fusion/README.md"
  "jnoccio-fusion/.gitignore"
  "jnoccio-fusion/.env.jnoccio.example"
  "jnoccio-fusion/KEYS.md"
  "jnoccio-fusion/ENCRYPTION.md"
)

is_exception() {
  for exc in "${EXCEPTIONS[@]}"; do [[ "$1" == "$exc" ]] && return 0; done
  return 1
}

ERRORS=0

for file in $STAGED; do
  is_exception "$file" && continue

  # Check if the file is being deleted (no content in index)
  if ! git show ":$file" &>/dev/null 2>&1; then
    continue
  fi

  # Read from the index (staged version)
  hex=$(git show ":$file" 2>/dev/null | head -c 10 | od -An -tx1 -v | tr -d ' \n')

  if [[ "$hex" != "$MAGIC_HEX" ]]; then
    echo "❌ Pre-commit: $file is PLAINTEXT in jnoccio-fusion/" >&2
    echo "   The git-crypt filter may not be active." >&2
    echo "   Run: git-crypt status" >&2
    echo "   Fix: git-crypt unlock, then re-stage the file." >&2
    ERRORS=$((ERRORS + 1))
  fi
done

if [[ "$ERRORS" -gt 0 ]]; then
  echo "" >&2
  echo "🚫 $ERRORS file(s) would be committed as plaintext." >&2
  echo "   Commit blocked. Fix and retry, or use --no-verify to skip." >&2
  exit 1
fi

echo "✅ Pre-commit: jnoccio-fusion encryption verified."
