# ZYAL v2.1 — Billion-LOC Monorepo Migration
#
# Migrate AuthContext → PrincipalContext across an enterprise monorepo with
# repo-graph indexing, scope control (no aimless grep), blast-radius pause,
# generated-zone protection, ownership-required approvals, and impacted-test
# selection. Hypothesis tournament per service when risk is high.

<<<ZYAL v1:daemon id=billion-loc-monorepo>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Enterprise monorepo migration"
  objective: |
    Migrate AuthContext → PrincipalContext across all services with
    impact-aware test selection, ownership routing, and merge-train delivery.
  risk:
    - Cross-service public-API change
    - Touches generated zones (must regen, not edit)
    - Migration table changes require DBA approval

repo_intelligence:
  scale: billion_loc
  indexes:
    - symbols
    - dependency_graph
    - test_graph
    - ownership
    - generated_zones
    - security_sinks
    - api_contracts
    - migration_zones
  generated_zones:
    - "**/*.gen.ts"
    - "**/*.pb.go"
    - "**/generated/**"
    - "**/dist/**"
  scope_control:
    require_scope_before_edit: true
    max_initial_scope_files: 50
    expand_scope_requires_evidence: true
  blast_radius:
    compute_on: [edit, checkpoint, promote]
    pause_when_score_gte: 0.75

stop:
  all:
    - shell:
        command: "jekko repo-graph status auth-context-migration --assert complete"
        timeout: 30s
        assert: { exit_code: 0 }
    - shell:
        command: "bazel test //... --test_tag_filters=affected"
        timeout: 600s
        assert: { exit_code: 0 }

tasks:
  ledger: sqlite
  discover:
    - command: "jekko repo-graph usages AuthContext --json"
      timeout: 60s

agents:
  supervisor:
    agent: plan
  workers:
    - id: migrators
      count: 8
      agent: build
      isolation: git_worktree
    - id: verifiers
      count: 4
      agent: build
      isolation: git_worktree

experiments:
  strategy: disjoint_tournament
  fork_from: last_green_checkpoint
  lanes:
    - id: minimal
      hypothesis: "Compatibility shim, no consumer changes."
      prompt_strategy: adapter_layer
      isolation: git_worktree
      timeout: 30m
    - id: service-by-service
      hypothesis: "Migrate each service in dependency order."
      prompt_strategy: service_by_service
      isolation: git_worktree
      timeout: 90m
    - id: contract-first
      hypothesis: "Pin the new contract, then evolve consumers."
      prompt_strategy: tests_first
      isolation: git_worktree
      timeout: 60m
  max_parallel: 2
  scoring:
    weights:
      tests_passed: 0.25
      typecheck_passed: 0.15
      api_compat_passed: 0.20
      security_clean: 0.20
      complexity_delta: 0.10
      diff_minimal: 0.10
    judge: { agent: critic, blind: true, must_use_different_provider: true }
  reduce:
    strategy: synthesize_best
    require_final_verification: true
  preserve_failed_lanes_as_negative_memory: true

quality:
  anti_vibe:
    enabled: true
    fail_closed: true
    block_test_deletion: true
    block_assertion_weakening: true
    block_silent_catch: true
    block_fake_data_fallback: true
    block_ts_ignore: true
  diff_budget:
    max_files_changed: 200
    max_added_lines: 8000
    on_violation: require_approval
  checks:
    - name: no-edit-generated
      pattern: "(\\.gen\\.ts|\\.pb\\.go|/generated/)"
      scope: file_diff
      on_violation: block_checkpoint
    - name: api-contract-change
      shell: "node scripts/diff-openapi.mjs --strict"
      scope: file_diff
      on_violation: require_approval

capabilities:
  default: deny
  rules:
    - id: read-anywhere
      tool: read
      decision: allow
    - id: edit-services
      tool: edit
      paths: ["services/**/src/**"]
      decision: allow
    - id: edit-shared
      tool: edit
      paths: ["packages/auth/**", "packages/principal/**"]
      decision: ask
      require_gate: shared_lib_review
    - id: edit-migrations
      tool: edit
      paths: ["**/migrations/**"]
      decision: ask
      require_gate: dba_review
    - id: bazel
      tool: shell
      command_regex: "^bazel (test|build|query) "
      decision: allow
  command_floor:
    always_block:
      - "git push --force"
      - "rm -rf /"
      - "DROP TABLE"
      - "DROP DATABASE"

approvals:
  gates:
    shared_lib_review:
      required_role: platform_team
      timeout: 24h
      on_timeout: pause
      require_evidence: [api_compat_report, downstream_impact_report]
    dba_review:
      required_role: dba
      timeout: 48h
      on_timeout: pause
      require_evidence: [migration_dry_run, rollback_plan]
    merge_train:
      required_role: code_owner
      require_evidence: [test_results, evidence_bundle, rollback_plan]
  escalation:
    chain: [code_owner, staff_engineer, eng_director]
    auto_escalate_after: 72h

evidence:
  require_before_promote:
    - type: bazel_affected_tests
      must_pass: true
    - type: api_contract_compat
      must_pass: true
    - type: ownership_approvals
      must_be_known: true
    - type: rollback_plan
      must_exist: true
    - type: blast_radius_score
      max_increase: 0.20
  bundle_format: json
  sign: sha256
  archive: true

models:
  profiles:
    plan: { provider: anthropic, model: claude-opus-4-7, reasoning: true }
    build: { provider: anthropic, model: claude-sonnet-4-6 }
    critic: { provider: openai, model: gpt-5, reasoning: true }
    summarizer: { provider: anthropic, model: claude-haiku-4-5-20251001 }
  routes:
    plan: plan
    implement: build
    review: critic
    compress: summarizer
  critic:
    must_differ_from_builder: true
    must_use_different_provider: true
  confidence_cap: 0.6

budgets:
  run:
    wall_clock: 48h
    cost_usd: 500.00
    on_exhaust: renew_with_approval
  task:
    iterations: 30
    cost_usd: 8.00
    on_exhaust: park
  experiment_lane:
    wall_clock: 90m
    cost_usd: 10.00
    on_exhaust: abort

rollback:
  required_when:
    touches_paths: ["**/migrations/**", "packages/auth/**", "infra/**"]
    risk_score_gte: 0.5
  plan_required: true
  verify_command: "git apply --reverse --check < .jekko/daemon/rollback.patch"
  on_failure_after_merge: revert_commit

done:
  require:
    - stop_conditions_met
    - requirements_verified
    - evidence_complete
    - ownership_approvals_complete
    - rollback_plan_recorded
    - blast_radius_acceptable
  forbid:
    - model_only_claim
    - generated_zones_edited
    - api_contract_unreviewed

ui:
  theme: jekko-gold
  banner: forever

permissions:
  shell: allow
  edit: allow
  git_commit: allow
  git_push: deny
  workers: allow
<<<END_ZYAL id=billion-loc-monorepo>>>
ZYAL_ARM RUN_FOREVER id=billion-loc-monorepo
