{
  "$schema": "https://opencode.ai/config.json",
  "model": "jnoccio/jnoccio-fusion",
  "small_model": "jnoccio/jnoccio-fusion",
  "provider": {
    "jnoccio": {
      "name": "Jnoccio",
      "npm": "@ai-sdk/openai-compatible",
      "api": "http://127.0.0.1:4317/v1",
      "env": [],
      "options": {
        "baseURL": "http://127.0.0.1:4317/v1",
        "apiKey": "jnoccio-local",
        "timeout": 900000,
        "chunkTimeout": 120000,
        "includeUsage": true,
      },
      "models": {
        "jnoccio-fusion": {
          "name": "Jnoccio (recommended)",
          "id": "jnoccio-fusion",
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 128000,
            "output": 32000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
      },
    },
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {
    "jnoccio": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--quiet",
        "--manifest-path",
        "./jnoccio-fusion/Cargo.toml",
        "--bin",
        "jnoccio-mcp",
        "--",
        "--config",
        "./jnoccio-fusion/config/server.json",
        "--ensure-server",
      ],
      "enabled": true,
      "timeout": 300000,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
