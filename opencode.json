{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
      "**/credentials.json": "deny"
    },
    "edit": {
      "*": "allow"
    },
    "bash": {
      "*": "deny",
      "sandboxctl run *": "allow",
      "sandboxctl status *": "allow",
      "sandboxctl export *": "allow",
      "sandboxctl list*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git grep*": "allow",
      "git ls-files*": "allow"
    }
  }
}
