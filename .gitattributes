# ── git-crypt: jnoccio-fusion protected source ──────────────────
# Everything under jnoccio-fusion/ is encrypted by default.
# Use ** to cover subdirectories (git-crypt requires this).
jnoccio-fusion/** filter=git-crypt diff=git-crypt

# Exceptions: files that should remain readable without the key.
jnoccio-fusion/README.md !filter !diff
jnoccio-fusion/.gitignore !filter !diff
jnoccio-fusion/.env.jnoccio.example !filter !diff
jnoccio-fusion/KEYS.md !filter !diff
jnoccio-fusion/ENCRYPTION.md !filter !diff

# Never encrypt git-crypt internals or repo infrastructure.
.gitattributes !filter !diff
.github/** !filter !diff
.git-crypt/** !filter !diff
tools/** !filter !diff
